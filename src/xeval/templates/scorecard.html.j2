<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <title>{{ report.title }}</title>
  <style>
    :root {
      color-scheme: light dark;
      --canvas: #f3f6fb;
      --surface: #ffffff;
      --surface-muted: #f8fafc;
      --ink: #162033;
      --muted: #627087;
      --line: #dfe5ee;
      --brand: #3157d5;
      --brand-soft: #e8edff;
      --pass: #15855b;
      --pass-soft: #dff5ec;
      --fail: #c43b4d;
      --fail-soft: #fde8eb;
      --warn: #a76405;
      --warn-soft: #fff0d5;
      --shadow: 0 12px 32px rgba(32, 46, 76, .08);
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --canvas: #0e1420;
        --surface: #161e2d;
        --surface-muted: #111927;
        --ink: #edf2fb;
        --muted: #9facbf;
        --line: #2c3749;
        --brand: #91a9ff;
        --brand-soft: #25335d;
        --pass: #62d4ab;
        --pass-soft: #163d34;
        --fail: #ff8997;
        --fail-soft: #4b222b;
        --warn: #f0b75f;
        --warn-soft: #49381b;
        --shadow: 0 12px 32px rgba(0, 0, 0, .24);
      }
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--canvas);
      color: var(--ink);
      font: 14px/1.5 Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    main { width: min(1180px, calc(100% - 32px)); margin: 0 auto; padding: 36px 0 64px; }
    h1, h2, h3, p { margin-top: 0; }
    h1 { margin-bottom: 8px; font-size: clamp(26px, 4vw, 40px); letter-spacing: -.035em; line-height: 1.1; }
    h2 { margin-bottom: 16px; font-size: 19px; letter-spacing: -.015em; }
    h3 { margin-bottom: 5px; font-size: 15px; }
    code, pre { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
    code { overflow-wrap: anywhere; }
    .muted { color: var(--muted); }
    .eyebrow { margin-bottom: 7px; color: var(--brand); font-size: 12px; font-weight: 750; letter-spacing: .1em; text-transform: uppercase; }
    .header { display: flex; align-items: flex-start; justify-content: space-between; gap: 24px; margin-bottom: 28px; }
    .header-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 9px; margin-top: 16px; color: var(--muted); }
    .pill { display: inline-flex; align-items: center; gap: 7px; border-radius: 999px; padding: 5px 10px; background: var(--brand-soft); color: var(--brand); font-size: 12px; font-weight: 750; }
    .pill::before { width: 7px; height: 7px; border-radius: 50%; background: currentColor; content: ""; }
    .status-completed { background: var(--pass-soft); color: var(--pass); }
    .status-pass { background: var(--pass-soft); color: var(--pass); }
    .status-failed, .status-error, .status-fail { background: var(--fail-soft); color: var(--fail); }
    .status-not-evaluated { background: var(--warn-soft); color: var(--warn); }
    .panel { margin-top: 22px; border: 1px solid var(--line); border-radius: 15px; background: var(--surface); box-shadow: var(--shadow); }
    .panel-head { display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 21px 22px 0; }
    .panel-body { padding: 20px 22px 22px; }
    .kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; }
    .kpi { min-height: 138px; padding: 18px; border: 1px solid var(--line); border-radius: 13px; background: var(--surface); box-shadow: var(--shadow); }
    .kpi-label { margin-bottom: 12px; color: var(--muted); font-size: 12px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }
    .kpi-value { font-size: 29px; font-weight: 770; letter-spacing: -.035em; line-height: 1.1; }
    .kpi-note { min-height: 21px; margin-top: 8px; color: var(--muted); font-size: 12px; }
    .signals { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; margin-top: 14px; }
    .signal { padding: 13px 15px; border: 1px solid var(--line); border-radius: 11px; background: var(--surface-muted); }
    .signal strong { display: block; margin-top: 3px; font-size: 20px; }
    .delta { display: inline-block; margin-top: 7px; border-radius: 6px; padding: 2px 7px; font-size: 12px; font-weight: 720; }
    .delta-up { background: var(--pass-soft); color: var(--pass); }
    .delta-down { background: var(--fail-soft); color: var(--fail); }
    .delta-flat { background: var(--surface-muted); color: var(--muted); }
    .comparison { display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 20px; margin-top: 14px; padding: 16px 18px; border: 1px solid var(--line); border-radius: 12px; background: var(--surface-muted); }
    .comparison strong { font-size: 15px; }
    .sparkline { display: block; width: 180px; height: 38px; overflow: visible; }
    .sparkline polyline { fill: none; stroke: var(--brand); stroke-linecap: round; stroke-linejoin: round; stroke-width: 2.7; vector-effect: non-scaling-stroke; }
    .sparkline .guide { stroke: var(--line); stroke-dasharray: 2 4; vector-effect: non-scaling-stroke; }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 13px 12px; border-bottom: 1px solid var(--line); text-align: right; vertical-align: middle; white-space: nowrap; }
    th { color: var(--muted); font-size: 11px; font-weight: 760; letter-spacing: .055em; text-transform: uppercase; }
    th:first-child, td:first-child { padding-left: 0; text-align: left; }
    th:last-child, td:last-child { padding-right: 0; }
    tr:last-child td { border-bottom: 0; }
    .category-name { font-weight: 710; }
    .slice { display: grid; grid-template-columns: minmax(80px, 1fr) auto; align-items: center; gap: 9px; min-width: 150px; }
    .bar { display: flex; height: 8px; overflow: hidden; border-radius: 999px; background: var(--line); }
    .bar-pass { background: var(--pass); }
    .bar-fail { background: var(--fail); }
    .error-count { color: var(--warn); }
    .sig { color: var(--brand); font-weight: 760; }
    .regressions { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
    .regression { min-width: 0; padding: 17px; border: 1px solid var(--line); border-left: 4px solid var(--fail); border-radius: 10px; background: var(--surface-muted); }
    .regression-head { display: flex; justify-content: space-between; gap: 12px; }
    .reason { color: var(--fail); font-size: 12px; font-weight: 760; white-space: nowrap; }
    .score-shift { margin: 9px 0; color: var(--muted); font-size: 12px; }
    .response { max-height: 210px; margin: 11px 0 0; overflow: auto; border: 1px solid var(--line); border-radius: 8px; padding: 11px; background: var(--surface); color: var(--ink); font-size: 12px; white-space: pre-wrap; word-break: break-word; }
    .empty { padding: 24px; border: 1px dashed var(--line); border-radius: 10px; color: var(--muted); text-align: center; }
    .details { display: grid; grid-template-columns: 1fr 1.3fr; gap: 22px; }
    .detail-list { display: grid; grid-template-columns: auto minmax(0, 1fr); gap: 9px 14px; margin: 0; }
    .detail-list dt { color: var(--muted); }
    .detail-list dd { min-width: 0; margin: 0; overflow-wrap: anywhere; }
    .hash-list { display: grid; gap: 10px; }
    .hash-row { display: grid; grid-template-columns: 155px minmax(0, 1fr); gap: 12px; }
    .hash-row span { color: var(--muted); }
    .footnote { margin: 22px 2px 0; color: var(--muted); font-size: 12px; }
    @media (max-width: 900px) {
      .kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .signals { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .details { grid-template-columns: 1fr; }
    }
    @media (max-width: 650px) {
      main { width: min(100% - 20px, 1180px); padding-top: 24px; }
      .header { display: block; }
      .kpis, .signals, .regressions { grid-template-columns: 1fr; }
      .comparison { grid-template-columns: 1fr; }
      .panel-head, .panel-body { padding-left: 16px; padding-right: 16px; }
    }
    @media print {
      :root { color-scheme: light; }
      body { background: #fff; }
      main { width: 100%; padding: 0; }
      .panel, .kpi { break-inside: avoid; box-shadow: none; }
    }
  </style>
</head>
<body>
{% macro percent(value, digits=1) -%}
  {%- if value is none -%}—{%- else -%}{{ ("%." ~ digits ~ "f")|format(value * 100) }}%{%- endif -%}
{%- endmacro %}
{% macro number(value, digits=3) -%}
  {%- if value is none -%}—{%- else -%}{{ ("%." ~ digits ~ "f")|format(value) }}{%- endif -%}
{%- endmacro %}
{% macro pvalue(value) -%}
  {%- if value is none -%}—{%- elif value < 0.001 -%}&lt;0.001{%- else -%}{{ "%.3f"|format(value) }}{%- endif -%}
{%- endmacro %}
{% macro delta(value, percent_value=true) -%}
  {%- if value is none -%}—
  {%- else -%}
    <span class="delta {% if value > 0 %}delta-up{% elif value < 0 %}delta-down{% else %}delta-flat{% endif %}">
      {% if value > 0 %}+{% endif %}{% if percent_value %}{{ "%.1f"|format(value * 100) }} pp{% else %}{{ "%.3f"|format(value) }}{% endif %}
    </span>
  {%- endif -%}
{%- endmacro %}

<main>
  <header class="header">
    <div>
      <p class="eyebrow">Black-box quality &amp; safety</p>
      <h1>{{ report.title }}</h1>
      <div class="header-meta">
        <span class="pill status-{{ (report.run.status or 'unknown')|lower }}">{{ report.run.status or "unknown" }}</span>
        <span class="pill status-{{ report.release_status }}">Release gate {{ report.release_status|replace('-', ' ') }}</span>
        <span>Run <code>{{ report.run.run_id or "unknown" }}</code></span>
        <span>Endpoint <code>{{ report.run.endpoint_version or "unknown" }}</code></span>
      </div>
    </div>
    <div class="muted">Generated {{ report.generated_at }}</div>
  </header>

  <section class="kpis" aria-label="Run summary">
    <article class="kpi">
      <div class="kpi-label">Probe outcomes</div>
      <div class="kpi-value">{{ report.summary.passed }} / {{ report.summary.total }}</div>
      <div class="kpi-note">{{ report.summary.failed }} failed · <span class="error-count">{{ report.summary.errors }} unevaluated/error</span></div>
    </article>
    <article class="kpi">
      <div class="kpi-label">Pass rate</div>
      <div class="kpi-value">{{ percent(report.summary.pass_rate) }}</div>
      <div class="kpi-note">{{ (report.confidence_level * 100)|round|int }}% bootstrap CI {{ percent(report.summary.pass_ci_low) }}–{{ percent(report.summary.pass_ci_high) }}</div>
      {% if report.previous_run %}{{ delta(report.summary.pass_delta) }}{% endif %}
    </article>
    <article class="kpi">
      <div class="kpi-label">Mean score</div>
      <div class="kpi-value">{{ number(report.summary.mean_score) }}</div>
      <div class="kpi-note">{{ (report.confidence_level * 100)|round|int }}% bootstrap CI {{ number(report.summary.score_ci_low) }}–{{ number(report.summary.score_ci_high) }}</div>
      {% if report.previous_run %}{{ delta(report.summary.score_delta, false) }}{% endif %}
    </article>
    <article class="kpi">
      <div class="kpi-label">Latency p95</div>
      <div class="kpi-value">{% if report.summary.latency_p95_ms is none %}—{% else %}{{ "%.0f"|format(report.summary.latency_p95_ms) }} <small>ms</small>{% endif %}</div>
      <div class="kpi-note">Median {% if report.summary.latency_p50_ms is none %}—{% else %}{{ "%.0f"|format(report.summary.latency_p50_ms) }} ms{% endif %}</div>
    </article>
  </section>

  {% if report.scoring_signals %}
  <section class="signals" aria-label="Scoring signals">
    {% for signal in report.scoring_signals %}
    <article class="signal">
      <span class="muted">{{ signal.label }}</span>
      <strong>{% if signal.display == 'percent' %}{{ percent(signal.value) }}{% else %}{{ number(signal.value) }}{% endif %}</strong>
      <span class="muted">n={{ signal.observations }}</span>
    </article>
    {% endfor %}
  </section>
  {% endif %}

  {% if report.previous_run %}
  <div class="comparison">
    <div>
      <strong>Paired comparison vs run <code>{{ report.previous_run.run_id }}</code></strong>
      <div class="muted">
        Pass-rate p={{ pvalue(report.summary.pass_p_value) }} from {{ report.summary.pass_pairs }} matched probes;
        score p={{ pvalue(report.summary.score_p_value) }} from {{ report.summary.score_pairs }} matched probes.
        {% if report.summary.pass_p_value is not none and report.summary.pass_p_value < (1 - report.confidence_level) %}<span class="sig">Pass-rate change is statistically significant.</span>{% endif %}
      </div>
    </div>
    {% if report.overall_sparkline_points %}
    <svg class="sparkline" viewBox="0 0 180 38" role="img" aria-label="Pass-rate history sparkline">
      <line class="guide" x1="0" y1="37" x2="180" y2="37"></line>
      <polyline points="{{ report.overall_sparkline_points }}"></polyline>
    </svg>
    {% endif %}
  </div>
  {% endif %}

  {% if report.gate_checks or report.regression_gate %}
  <section class="panel">
    <div class="panel-head">
      <div>
        <h2>Release gates</h2>
        <p class="muted">Absolute policy thresholds, completion coverage, and the paired prior-run decision.</p>
      </div>
      <span class="pill status-{{ report.release_status }}">{{ report.release_status|replace('-', ' ') }}</span>
    </div>
    <div class="panel-body table-wrap">
      <table>
        <thead><tr><th>Gate</th><th>Observed</th><th>Requirement</th><th>n</th><th>Status</th></tr></thead>
        <tbody>
        {% for gate in report.gate_checks %}
          <tr>
            <td>{{ gate.name|replace('_', ' ')|title }}</td>
            <td>{% if gate.value is none %}-{% elif gate.name.endswith('_rate') %}{{ percent(gate.value) }}{% else %}{{ number(gate.value) }}{% endif %}</td>
            <td><code>{{ gate.operator }} {% if gate.threshold is none %}-{% elif gate.name.endswith('_rate') %}{{ percent(gate.threshold) }}{% else %}{{ number(gate.threshold) }}{% endif %}</code></td>
            <td>{{ gate.observations }}</td>
            <td><span class="pill status-{% if gate.passed %}pass{% else %}fail{% endif %}">{% if gate.passed %}pass{% else %}fail{% endif %}</span></td>
          </tr>
        {% endfor %}
        {% if report.regression_gate %}
          <tr>
            <td>Prior-run regression</td>
            <td>Delta {{ number(report.regression_gate.delta) }}, p={{ pvalue(report.regression_gate.p_value) }}{% if report.regression_gate.critical_count %} / {{ report.regression_gate.critical_count }} critical flips{% endif %}</td>
            <td>drop &gt;= {{ number(report.regression_gate.minimum_delta) }} and p &lt; {{ number(report.regression_gate.alpha) }}</td>
            <td>{{ report.regression_gate.pairs }}</td>
            <td><span class="pill status-{% if report.regression_gate.regression %}fail{% else %}pass{% endif %}">{% if report.regression_gate.regression %}fail{% else %}pass{% endif %}</span></td>
          </tr>
        {% endif %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  <section class="panel">
    <div class="panel-head">
      <div>
        <h2>Category slices</h2>
        <p class="muted">Pass/fail distribution, uncertainty, and matched-probe change.</p>
      </div>
    </div>
    <div class="panel-body table-wrap">
      <table>
        <thead>
          <tr>
            <th>Category</th>
            <th>Pass / fail</th>
            <th>Pass rate (CI)</th>
            <th>Δ vs prior</th>
            <th>p-value</th>
            <th>Mean score</th>
            <th>p95 latency</th>
            <th>History</th>
          </tr>
        </thead>
        <tbody>
        {% for category in report.categories %}
          <tr>
            <td>
              <div class="category-name">{{ category.category }}</div>
              <div class="muted">n={{ category.total }}{% if category.errors %} · {{ category.errors }} errors{% endif %}</div>
            </td>
            <td>
              <div class="slice">
                <div class="bar" aria-label="{{ category.passed }} passed and {{ category.failed }} failed">
                  <span class="bar-pass" style="width: {{ (category.passed / category.evaluated * 100) if category.evaluated else 0 }}%"></span>
                  <span class="bar-fail" style="width: {{ (category.failed / category.evaluated * 100) if category.evaluated else 0 }}%"></span>
                </div>
                <span>{{ category.passed }} / {{ category.failed }}</span>
              </div>
            </td>
            <td>{{ percent(category.pass_rate) }} <span class="muted">({{ percent(category.pass_ci_low) }}–{{ percent(category.pass_ci_high) }})</span></td>
            <td>{{ delta(category.pass_delta) }}</td>
            <td class="{% if category.pass_p_value is not none and category.pass_p_value < (1 - report.confidence_level) %}sig{% endif %}">{{ pvalue(category.pass_p_value) }}</td>
            <td>{{ number(category.mean_score) }}</td>
            <td>{% if category.latency_p95_ms is none %}—{% else %}{{ "%.0f"|format(category.latency_p95_ms) }} ms{% endif %}</td>
            <td>
              {% if category.sparkline_points %}
              <svg class="sparkline" viewBox="0 0 180 38" role="img" aria-label="{{ category.category }} pass-rate history">
                <polyline points="{{ category.sparkline_points }}"></polyline>
              </svg>
              {% else %}<span class="muted">—</span>{% endif %}
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel">
    <div class="panel-head">
      <div>
        <h2>Regression samples</h2>
        <p class="muted">Matched probes that flipped from pass to fail or crossed the configured score-drop threshold.</p>
      </div>
      <span class="pill">{{ report.regressions|length }} samples</span>
    </div>
    <div class="panel-body">
      {% if not report.include_regression_samples %}
      <div class="empty">Regression response samples are disabled for this report.</div>
      {% elif report.regressions %}
      <div class="regressions">
      {% for sample in report.regressions %}
        <article class="regression">
          <div class="regression-head">
            <div>
              <h3>{{ sample.category }}</h3>
              <code class="muted" title="{{ sample.probe_hash }}">{{ sample.probe_hash }}</code>
            </div>
            <span class="reason">{{ sample.reason }}</span>
          </div>
          <div class="score-shift">Score {{ number(sample.previous_score) }} → {{ number(sample.current_score) }} · response {{ sample.response_disposition }}</div>
          {% if sample.response_text is not none %}
          <pre class="response">{{ sample.response_text }}</pre>
          {% else %}
          <div class="empty">No response sample was stored as safe or redacted.</div>
          {% endif %}
        </article>
      {% endfor %}
      </div>
      {% else %}
      <div class="empty">No matched regressions detected against the compatible prior run.</div>
      {% endif %}
    </div>
  </section>

  {% if report.history %}
  <section class="panel">
    <div class="panel-head"><h2>Run history</h2></div>
    <div class="panel-body table-wrap">
      <table>
        <thead><tr><th>Run</th><th>Started</th><th>Endpoint</th><th>Pass rate</th><th>Mean score</th></tr></thead>
        <tbody>
        {% for point in report.history %}
          <tr>
            <td><code>{{ point.run_id }}</code></td>
            <td>{{ point.label }}</td>
            <td><code>{{ point.endpoint_version }}</code></td>
            <td>{{ percent(point.pass_rate) }}</td>
            <td>{{ number(point.mean_score) }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  <section class="panel">
    <div class="panel-head"><h2>Reproducibility manifest</h2></div>
    <div class="panel-body details">
      <dl class="detail-list">
        <dt>Run ID</dt><dd><code>{{ report.run.run_id or "unknown" }}</code></dd>
        <dt>Started</dt><dd>{{ report.run.started_at or "—" }}</dd>
        <dt>Completed</dt><dd>{{ report.run.completed_at or "—" }}</dd>
        <dt>Endpoint version</dt><dd><code>{{ report.run.endpoint_version or "unknown" }}</code></dd>
        <dt>Bootstrap seed</dt><dd><code>{{ report.seed }}</code></dd>
        <dt>Resamples</dt><dd>{{ report.bootstrap_resamples }} bootstrap · {{ report.permutation_resamples }} sign-flip</dd>
      </dl>
      <div class="hash-list">
      {% for label, value in report.hashes.items() %}
        <div class="hash-row"><span>{{ label|replace('_', ' ')|title }}</span><code>{{ value or "not recorded" }}</code></div>
      {% endfor %}
      {% for label, value in report.metadata.items() %}
        <div class="hash-row"><span>{{ label|replace('_', ' ')|title }}</span><code>{{ value }}</code></div>
      {% endfor %}
      </div>
    </div>
  </section>

  <p class="footnote">
    Confidence intervals use a deterministic percentile bootstrap. P-values use a two-sided paired sign-flip randomisation test on probes present in both runs; p-values are descriptive when sample sizes are small. Raw prompts are not included in this report.
  </p>
</main>
</body>
</html>
